# Salin file ini ke .env dan isi nilainya
# cp .env.example .env

# WAJIB diubah di production!
SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-acak

# Set False di production
DEBUG=False

# Daftar domain yang diizinkan (pisahkan dengan koma)
ALLOWED_HOSTS=localhost,127.0.0.1,domain-anda.com

# URL domain production (dipakai di email welcome & link sistem)
SITE_URL=https://domain-anda.com

# Kontak sales — tampil di halaman upgrade trial
SALES_WA=628XXXXXXXXXX
SALES_EMAIL=sales@domain-anda.com

# CORS: domain frontend yang diizinkan akses API
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://domain-anda.com

# Email HR untuk notifikasi
HR_EMAIL_LIST=hr@domain-anda.com

# Email konfigurasi
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@domain-anda.com
EMAIL_HOST_PASSWORD=app-password-disini
DEFAULT_FROM_EMAIL=HRIS SmartDesk <noreply@domain-anda.com>
