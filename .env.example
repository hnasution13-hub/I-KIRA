# ============================================================
#  HRIS SmartDesk — Environment Variables
#  Salin ke .env lalu isi nilainya:  cp .env.example .env
# ============================================================

# ── App ──────────────────────────────────────────────────────
SECRET_KEY=ganti-dengan-secret-key-panjang-dan-acak-min-50-karakter
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,domain-anda.com

# ── Database: Neon PostgreSQL ────────────────────────────────
# Dapatkan dari: https://console.neon.tech → project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── Storage: Cloudinary ──────────────────────────────────────
# Dapatkan dari: https://cloudinary.com/console → Dashboard
CLOUDINARY_CLOUD_NAME=nama-cloud-anda
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (SMTP) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@domain-anda.com
EMAIL_HOST_PASSWORD=app-password-16-karakter-dari-google
DEFAULT_FROM_EMAIL=HRIS SmartDesk <noreply@domain-anda.com>
HR_EMAIL_LIST=hr@domain-anda.com

# ── URL & CORS ────────────────────────────────────────────────
SITE_URL=https://domain-anda.com
CORS_ALLOWED_ORIGINS=https://domain-anda.com

# ── Kontak Sales ──────────────────────────────────────────────
SALES_WA=628XXXXXXXXXX
SALES_EMAIL=sales@domain-anda.com
